@model CourseRegistrationSystem.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<h2>Student Details</h2>
<hr />

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Student ID</dt>
            <dd class="col-sm-8"><span class="badge bg-primary">@Model.StudentId</span></dd>

            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Major</dt>
            <dd class="col-sm-8">@Model.Major</dd>

            <dt class="col-sm-4">Year</dt>
            <dd class="col-sm-8">@Model.Year</dd>

            <dt class="col-sm-4">GPA</dt>
            <dd class="col-sm-8">@Model.GPA?.ToString("F1")</dd>
        </dl>
    </div>
</div>

<h4 class="mt-4">Registered Courses (@Model.Registrations.Count)</h4>
@if (Model.Registrations.Any())
{
    <table class="table table-bordered" style="max-width: 600px;">
        <thead class="table-dark">
            <tr>
                <th>Code</th>
                <th>Course Name</th>
                <th>Credits</th>
                <th>Semester</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var reg in Model.Registrations)
            {
                <tr>
                    <td>@reg.Course?.Code</td>
                    <td>@reg.Course?.Name</td>
                    <td>@reg.Course?.Credits</td>
                    <td>@reg.Course?.Semester</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Not enrolled in any courses yet.</p>
}

<br />
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
