@model CourseRegistrationSystem.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<h2>Delete Course</h2>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete this course?
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Course Code</dt>
            <dd class="col-sm-8">@Model.Code</dd>

            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Credits</dt>
            <dd class="col-sm-8">@Model.Credits</dd>

            <dt class="col-sm-4">Instructor</dt>
            <dd class="col-sm-8">@Model.Instructor</dd>

            <dt class="col-sm-4">Semester</dt>
            <dd class="col-sm-8">@Model.Semester</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.Status</dd>
        </dl>
    </div>
</div>

<br />
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Yes, Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
