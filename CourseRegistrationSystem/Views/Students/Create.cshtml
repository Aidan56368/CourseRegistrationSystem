@model CourseRegistrationSystem.Models.Student

@{
    ViewData["Title"] = "Add Student";
}

<h2>Add New Student</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="StudentId" class="form-label"></label>
                <input asp-for="StudentId" class="form-control" placeholder="e.g. S004" />
                <span asp-validation-for="StudentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Jane Doe" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="e.g. jane@school.edu" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Major" class="form-label"></label>
                <input asp-for="Major" class="form-control" placeholder="e.g. Computer Science" />
                <span asp-validation-for="Major" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Year" class="form-label"></label>
                <select asp-for="Year" class="form-select">
                    <option>Freshman</option>
                    <option>Sophomore</option>
                    <option>Junior</option>
                    <option>Senior</option>
                    <option>Graduate</option>
                </select>
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="GPA" class="form-label"></label>
                <input asp-for="GPA" class="form-control" type="number" step="0.1" min="0" max="4.0" placeholder="0.0 - 4.0" />
                <span asp-validation-for="GPA" class="text-danger"></span>
            </div>

            <div>
                <input type="submit" value="Add Student" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
