@model CourseRegistrationSystem.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<h2>Delete Student</h2>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete this student?
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Student ID</dt>
            <dd class="col-sm-8">@Model.StudentId</dd>

            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Major</dt>
            <dd class="col-sm-8">@Model.Major</dd>

            <dt class="col-sm-4">Year</dt>
            <dd class="col-sm-8">@Model.Year</dd>

            <dt class="col-sm-4">GPA</dt>
            <dd class="col-sm-8">@Model.GPA?.ToString("F1")</dd>
        </dl>
    </div>
</div>

<br />
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Yes, Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
