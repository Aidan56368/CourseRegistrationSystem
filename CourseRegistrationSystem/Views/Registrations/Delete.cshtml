@model CourseRegistrationSystem.Models.Registration

@{
    ViewData["Title"] = "Drop Registration";
}

<h2>Drop Registration</h2>
<hr />

<div class="alert alert-warning">
    Are you sure you want to drop this registration?
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Student</dt>
            <dd class="col-sm-8">@Model.Student?.Name (@Model.Student?.StudentId)</dd>

            <dt class="col-sm-4">Course</dt>
            <dd class="col-sm-8">@Model.Course?.Name</dd>

            <dt class="col-sm-4">Course Code</dt>
            <dd class="col-sm-8">@Model.Course?.Code</dd>

            <dt class="col-sm-4">Credits</dt>
            <dd class="col-sm-8">@Model.Course?.Credits</dd>

            <dt class="col-sm-4">Date Registered</dt>
            <dd class="col-sm-8">@Model.RegistrationDate.ToShortDateString()</dd>
        </dl>
    </div>
</div>

<br />
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Yes, Drop Course" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
