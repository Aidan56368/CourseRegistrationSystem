@model CourseRegistrationSystem.Models.Registration

@{
    ViewData["Title"] = "Register Student";
}

<h2>Register Student for a Course</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="StudentId" class="form-label">Student</label>
                <select asp-for="StudentId" class="form-select" asp-items="ViewBag.Students">
                    <option value="">-- Select a Student --</option>
                </select>
                <span asp-validation-for="StudentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CourseId" class="form-label">Course</label>
                <select asp-for="CourseId" class="form-select" asp-items="ViewBag.Courses">
                    <option value="">-- Select a Course --</option>
                </select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>

            <div>
                <input type="submit" value="Register" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
