@model CourseRegistrationSystem.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<h2>Course Details</h2>
<hr />

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Course Code</dt>
            <dd class="col-sm-8">@Model.Code</dd>

            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Credits</dt>
            <dd class="col-sm-8">@Model.Credits</dd>

            <dt class="col-sm-4">Capacity</dt>
            <dd class="col-sm-8">@Model.Capacity</dd>

            <dt class="col-sm-4">Instructor</dt>
            <dd class="col-sm-8">@Model.Instructor</dd>

            <dt class="col-sm-4">Semester</dt>
            <dd class="col-sm-8">@Model.Semester</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                @if (Model.Status == "Open")
                {
                    <span class="badge bg-success">Open</span>
                }
                else
                {
                    <span class="badge bg-danger">Closed</span>
                }
            </dd>
        </dl>
    </div>
</div>

<h4 class="mt-4">Enrolled Students (@Model.Registrations.Count)</h4>
@if (Model.Registrations.Any())
{
    <table class="table table-bordered" style="max-width: 500px;">
        <thead class="table-dark">
            <tr>
                <th>Student ID</th>
                <th>Name</th>
                <th>Date Registered</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var reg in Model.Registrations)
            {
                <tr>
                    <td>@reg.Student?.StudentId</td>
                    <td>@reg.Student?.Name</td>
                    <td>@reg.RegistrationDate.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No students enrolled yet.</p>
}

<br />
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
