@model CourseRegistrationSystem.Models.Course

@{
    ViewData["Title"] = "Add Course";
}

<h2>Add New Course</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" placeholder="e.g. CS101" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Introduction to Computer Science" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Credits" class="form-label"></label>
                <input asp-for="Credits" class="form-control" type="number" min="1" max="6" />
                <span asp-validation-for="Credits" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Capacity" class="form-label"></label>
                <input asp-for="Capacity" class="form-control" type="number" min="1" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Instructor" class="form-label"></label>
                <input asp-for="Instructor" class="form-control" placeholder="e.g. Dr. Smith" />
                <span asp-validation-for="Instructor" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Semester" class="form-label"></label>
                <select asp-for="Semester" class="form-select">
                    <option>Spring 2026</option>
                    <option>Summer 2026</option>
                    <option selected>Fall 2026</option>
                    <option>Spring 2027</option>
                </select>
                <span asp-validation-for="Semester" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select">
                    <option selected>Open</option>
                    <option>Closed</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div>
                <input type="submit" value="Add Course" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
